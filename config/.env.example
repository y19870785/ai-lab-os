
# AI-Lab 环境变量示例

# 应用
AI_LAB_DEBUG=true
AI_LAB_SECRET_KEY=your-secret-key-here

# 数据库
AI_LAB_DB_HOST=localhost
AI_LAB_DB_PORT=5432
AI_LAB_DB_NAME=ai_lab
AI_LAB_DB_USER=postgres
AI_LAB_DB_PASSWORD=your-password-here

# Redis
AI_LAB_REDIS_HOST=localhost
AI_LAB_REDIS_PORT=6379
AI_LAB_REDIS_PASSWORD=

# OpenAI / LLM
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=gpt-4o

# Vector DB
AI_LAB_VECTOR_DB_PATH=data/vectors

# Logging
AI_LAB_LOG_LEVEL=INFO
